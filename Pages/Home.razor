@page "/"

<PageTitle>Home</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <h1 class="display-4">Welcome to EventEaseApp</h1>
            <p class="lead text-muted">Your simple event management solution</p>
            
            <div class="mt-5">
                <p>Explore our features:</p>
                <div class="d-grid gap-3 mt-4">
                    <a href="/events" class="btn btn-primary btn-lg">
                        <span class="bi bi-calendar-event me-2"></span>Browse Events
                    </a>
                    <a href="/events/manage" class="btn btn-outline-primary btn-lg">
                        <span class="bi bi-gear me-2"></span>Manage Events
                    </a>
                    <a href="/attendance" class="btn btn-outline-success btn-lg">
                        <span class="bi bi-graph-up me-2"></span>Attendance Tracker
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
