@page "/events"
@using EventEaseApp.Data
@using EventEaseApp.Models
@inject IEventService EventService

<PageTitle>Events</PageTitle>

<div class="container py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start mb-3">
        <div>
            <h1 class="h4">Events</h1>
            <p class="text-muted">Browse events and view details or register.</p>
        </div>
        <a class="btn btn-outline-secondary mt-3 mt-md-0" href="/Course4-EventEaseApp-12345/">Back to Home</a>
    </div>

    @if (!events.Any())
    {
        <div class="alert alert-info">No events available.</div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var e in events)
            {
                <div class="col-md-6">
                    <div class="card p-3">
                        <h5 class="mb-1">@e.Name</h5>
                        <div class="small text-muted">@e.Date.ToString("f") • @e.Location</div>
                        <div class="mt-2 small text-muted">Attendance: @e.AttendanceCount</div>
                        <div class="mt-3 d-flex gap-2">
                            <a class="btn btn-sm btn-primary" href="/events/@e.Id">Details</a>
                            <a class="btn btn-sm btn-outline-secondary" href="/events/@e.Id/register">Register</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private IReadOnlyList<EventItem> events = Array.Empty<EventItem>();

    protected override async Task OnInitializedAsync()
    {
        await EventService.LoadAsync();
        events = EventService.GetEvents();
        EventService.EventsChanged += Refresh;
    }

    private void Refresh()
    {
        events = EventService.GetEvents();
        StateHasChanged();
    }

    public void Dispose()
    {
        EventService.EventsChanged -= Refresh;
    }
}
